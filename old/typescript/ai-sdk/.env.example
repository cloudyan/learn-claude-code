# OpenAI API 配置（支持兼容 OpenAI 格式的国内大模型服务）
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4-turbo

# 也可以使用通用的 API 配置
# API_KEY=your-api-key-here
# API_BASE_URL=https://your-compatible-openai-api.com/v1

# 可选：自定义配置
# MODEL_NAME=qwen-max (通义千问)
# MODEL_NAME=ernie-bot-4.5 (文心一言)
# MODEL_NAME=glm-4 (智谱AI)
